{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public"
      }
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "^/$", "dest": "/pages/index.html" },
    { "src": "^/index\.html$", "dest": "/pages/index.html" },
    { "src": "^/(register|login|browse-skills|dashboard|profile|add-skill)\.html$", "dest": "/pages/$1.html" },
    { "src": "^/(.*)$", "dest": "/$1" }
  ]
}
